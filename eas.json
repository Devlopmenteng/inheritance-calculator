{
  "cli": {
    "version": ">= 7.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradle": {
          "java": {
            "version": "17"
          }
        }
      },
      "env": {
        "APP_ENV": "preview"
      }
    },
    "production": {
      "android": {
        "buildType": "apk",
        "gradle": {
          "java": {
            "version": "17"
          }
        }
      },
      "env": {
        "APP_ENV": "production"
      }
    }
  }
}
